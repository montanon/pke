{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Report",
  "type": "object",
  "required": [
    "type",
    "version",
    "report_id",
    "snapshot_id",
    "reason_category",
    "reported_by_signing_public_key",
    "report_timestamp",
    "report_signature"
  ],
  "properties": {
    "type": { "const": "report" },
    "version": { "type": "string" },
    "report_id": { "type": "string" },
    "snapshot_id": { "type": "string" },
    "reason_category": {
      "type": "string",
      "enum": ["abuse_concern", "legal_request", "owner_request", "other"]
    },
    "reported_by_signing_public_key": { "type": "string" },
    "report_timestamp": { "type": "string", "format": "date-time" },
    "report_signature": { "type": "string" }
  },
  "additionalProperties": false
}
